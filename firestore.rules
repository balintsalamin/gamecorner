// ============================================================================
// Firestore biztonsági szabályok – Gamecorner szobák (Colorcards, Holland kocsma)
// ============================================================================
// Másold be ezt a Firebase konzolban:
// Build → Firestore Database → Rules fül → illeszd be → Publish
//
// Mit csinál ez?
// - Csak a "rooms" (Colorcards) és a "hkRooms" (Holland kocsma) kollekciókhoz
//   enged hozzáférést, és csak akkor, ha a dokumentum ID-ja pontosan 4
//   karakteres (ez a szobakód formátuma).
// - Mindent mást (más kollekciókat) letilt.
//
// Új játék hozzáadásakor: ha az új játék saját Firestore kollekciót használ
// (lásd a játék main.js-ében a ROOMS_COLLECTION nevét), másolj be ide egy
// hasonló match blokkot az új kollekció nevével.
//
// FONTOS – ennek a projektnek a korlátai:
// Nincs bejelentkezés/azonosítás, így bárki, aki ismeri (vagy kitalálja) egy
// szoba 4 karakteres kódját, olvashatja és írhatja azt a szobát. Ez egy
// ingyenes, kiszolgáló nélküli, baráti/családi használatra szánt megoldás –
// NE tárolj benne semmi érzékeny adatot. A 4 karakteres kód (kb. 1 millió
// kombináció) elég ahhoz, hogy idegenek véletlenül ne találjanak rá egy
// aktív szobára.
// ============================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read, write: if roomId.size() == 4;
    }

    // Holland kocsma szobái – külön kollekció, hogy ne keveredjen össze a
    // Colorcards szobakódjaival, ugyanazokkal a korlátokkal.
    match /hkRooms/{roomId} {
      allow read, write: if roomId.size() == 4;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
